# Server
PORT=3000
WS_PORT=3001
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=waste_management
DB_POOL_MIN=2
DB_POOL_MAX=10

# Security
TOKEN_SECRET=your_256bit_secret_key_change_this_in_production
TOKEN_EXPIRY_SECONDS=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Body Size Limit (bytes)
MAX_BODY_SIZE=1048576
